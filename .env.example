# =============================================================================
# 云平台内测发布配置示例
# 复制本文件为 .env 并填入真实值;真实 .env 已被 .gitignore 忽略,不会提交。
# 也可以将变量放在系统环境变量或 CI/CD Secret 中,优先级:系统环境 > .env。
# =============================================================================

# -------- 蒲公英 Pgyer --------
# 蒲公英 API Key(在 https://www.pgyer.com/account/api 获取)
PGYER_API_KEY=

# 安装密码:用户打开下载页时输入的密码(2 位以上,建议 6 位)
PGYER_INSTALL_PASSWORD=

# 安装方式:1 = 密码安装,2 = 邀请安装。可选,默认 1。
PGYER_BUILD_INSTALL_TYPE=1

# 默认更新说明,可通过 --desc 参数覆盖
PGYER_BUILD_UPDATE_DESCRIPTION=内测版本,问题反馈请联系项目负责人

# APK 打包产物路径;留空则使用默认 apks/cloud-platform.apk
APK_OUTPUT_PATH=

# 下载链接有效期提示(天),仅作为邮件中的提示文案;蒲公英本身不强制过期
DOWNLOAD_LINK_EXPIRE_DAYS=7

# 应用元数据(也可用 CLI 参数覆盖)
APP_NAME=云平台数据通信
VERSION_NAME=1.0.0
VERSION_CODE=1

# -------- 邮件服务(EmailJS REST) --------
# EmailJS 公共密钥
EMAILJS_PUBLIC_KEY=

# EmailJS Service ID
EMAILJS_SERVICE_ID=

# EmailJS Template ID
# ⚠️ 必须为发布通知新建独立模板,不要直接复用「配置导出」模板
# (那个模板主题 hard-code 为「云平台数据通信 - 配置导出」,会忽略下载链接)
# 模板必须引用这些变量:to_email / subject / app_name / version_name /
#   version_code / file_size / download_url / install_password /
#   update_description / expire_days
EMAILJS_TEMPLATE_ID=

# 默认收件人邮箱(可通过 --email 覆盖)
RECEIVER_EMAIL=

# -------- DCloud / uniCloud H5 部署 --------
# 用于 scripts/deploy-h5.ps1 自动登录并发布 H5 到 uniCloud 前端网页托管。
# 真实账号密码只写入本机 .env，不要提交到 Git。
DCLOUD_USERNAME=
DCLOUD_PASSWORD=
DCLOUD_PROVIDER=aliyun
DCLOUD_SPACE_ID=mp-70459e72-3958-42a0-9743-4e80b54716cd
