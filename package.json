    "@dcloudio/uni-h5": "3.0.0-alpha-5010320260611001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5010320260611001",
    "crypto-js": "^4.2.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5010320260611001",
    "vite": "5.2.8"
